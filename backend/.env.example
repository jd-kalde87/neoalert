# Copy to .env and adjust for your environment:
#   Copy-Item .env.example .env

# ---------------------------------------------------------------------------
# Identity Service — JWT, email, OAuth
# ---------------------------------------------------------------------------
IDENTITYSERVICE_JWT_SECRET_KEY=change-me-in-production
IDENTITYSERVICE_FRONTEND_URL=http://localhost:5173
# Shorthand aliases (optional; IDENTITYSERVICE_FRONTEND_URL takes precedence):
# FRONTEND_URL=http://localhost:5173
# APP_URL=http://localhost:5173
IDENTITYSERVICE_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Email adapter: console (log only) | smtp (real delivery)
IDENTITYSERVICE_EMAIL_ADAPTER=console
IDENTITYSERVICE_SMTP_HOST=localhost
IDENTITYSERVICE_SMTP_PORT=587
IDENTITYSERVICE_SMTP_USER=
IDENTITYSERVICE_SMTP_PASSWORD=
IDENTITYSERVICE_SMTP_FROM_EMAIL=noreply@neoalert.local
IDENTITYSERVICE_SMTP_USE_TLS=true

IDENTITYSERVICE_GOOGLE_CLIENT_ID=
IDENTITYSERVICE_GOOGLE_CLIENT_SECRET=
IDENTITYSERVICE_GOOGLE_REDIRECT_URI=http://localhost:8001/auth/google/callback
IDENTITYSERVICE_VERIFICATION_TOKEN_EXPIRE_HOURS=24
IDENTITYSERVICE_PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1
